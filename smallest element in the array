import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
      int n,low,i;
      Scanner v=new Scanner(System.in);
      n=v.nextInt();
      int arr[]=new int[50];
      for(i=0;i<n;i++){
        arr[i]=v.nextInt();
      }
        low=arr[0];
      
      for(i=1;i<n;i++){
        
        if(low > arr[i]){
          low=arr[i];
        }
      }
      System.out.println(low);
      
    }
}
