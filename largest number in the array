import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
      int n,max,i;
      Scanner v=new Scanner(System.in);
      n=v.nextInt();
      int arr[]=new int[50];
      for(i=0;i<n;i++){
        arr[i]=v.nextInt();
      }
        max=arr[0];
      
      for(i=1;i<n;i++){
        
        if(max < arr[i]){
          max=arr[i];
        }
      }
      System.out.println(max);
      
    }
}
