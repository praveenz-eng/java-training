import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int a,b,c;
        Scanner n=new Scanner(System.in);
        a=n.nextInt();
        b=n.nextInt();
        c=n.nextInt();
        if(a<b&&b<c)
        {
            System.out.println(a);
        }
        else if(b>a&&b>c)
        {
            System.out.println(b);
        }
        else
        {
            System.out.println(c);
        }
    }
}
