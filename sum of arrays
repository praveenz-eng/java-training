import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int i,n,sum=0;
      Scanner c=new Scanner(System.in);
      n=c.nextInt();
      int[]arr=new int[n];
      for(i=0;i<n;i++){
        arr[i]=c.nextInt();
      }
      for(i=0;i<n;i++){
        sum=sum+arr[i];
      }
      {
        System.out.print(sum);
      }
      
    }
}
